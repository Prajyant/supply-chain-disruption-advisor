# API Keys
OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# Amazon Bedrock
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_SESSION_TOKEN=your-aws-session-token-if-using-temporary-credentials
        
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# JWT Secret (change in production)
JWT_SECRET=your-secret-key-change-in-production

# Firebase Auth Backend
# Use FIREBASE_PROJECT_ID for token verification, or FIREBASE_SERVICE_ACCOUNT_KEY for a service account JSON path.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_KEY=

# Database
DATABASE_URL=sqlite:///./supply_chain.db

# API URLs
STREAMLIT_API_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000

# Vessel tracking
# No API key is required when the frontend tracker sends live vessel latitude/longitude in shipment input.
# Optional fallback only: if configured, backend can call this endpoint with ?imo=<number>.
VESSEL_TRACKER_API_URL=
VESSEL_TRACKER_API_KEY=

# === Vessel Tracking (AIS Fleet Monitoring) ===
AIS_PROVIDER=demo                           
AIS_API_KEY=3633af3320b652dd0332c5b7317d95d76b64e6ef
WATCHLIST_CSV_PATH=./watchlist.csv
VESSEL_POLL_INTERVAL_SECONDS=300               # How often to fetch positions (default 5 min)
VESSEL_SILENCE_THRESHOLD_HOURS=6               # When to flag as AIS-silent
VESSEL_STALE_THRESHOLD_HOURS=1                 # When to show yellow status
VESSEL_HISTORY_RETENTION_DAYS=90               # Auto-purge old positions
VESSEL_IDENTITY_CACHE_DAYS=30                  # Re-resolve identity after this many days

# === Vessel Registry (Equasis) ===
# Free account at equasis.org — provides inspection/detention history
EQUASIS_USERNAME=kaur.taran223@gmail.com
EQUASIS_PASSWORD=2yyGeBDGa9!c#2y
VESSEL_REGISTRY_CACHE_DB=data/vessel_registry_cache.db
VESSEL_REGISTRY_CACHE_DAYS=30

# === Sanctions Monitoring (OFAC + UN) ===
# No credentials needed — public data sources
SANCTIONS_CACHE_DB=data/sanctions_cache.db
SANCTIONS_CACHE_HOURS=24

# === Tariff Monitoring (WTO/WITS) ===
# No credentials needed — public APIs
TARIFF_CACHE_DB=data/tariff_cache.db
TARIFF_CACHE_DAYS=7


# AWS SES Email Notifications
# Sender must be verified in SES (or entire domain verified)
SES_SENDER_EMAIL=supplychain.disruptionadvisor@gmail.com
# Fallback recipients (used when role-specific list is empty)
SES_ALERT_RECIPIENTS=kashish.xa@gmail.com,taranpreet.kaur591@gmail.com

# Role-based alert routing (comma-separated emails per role)
# Operations: shipment delays, logistics issues, port disruptions, weather
SES_RECIPIENTS_OPERATIONS=
# Finance: tariff changes, cost impacts, budget overruns, currency issues
SES_RECIPIENTS_FINANCE=
# Analyst: risk assessments, market trends, geopolitical, trade policy
SES_RECIPIENTS_ANALYST=
# Executive: critical escalations, supplier bankruptcy, sanctions, force majeure
SES_RECIPIENTS_EXECUTIVE=

# Optional: override region for SES (defaults to AWS_REGION)
SES_REGION=
