# Maritime AI Risk Intelligence Platform - Environment Configuration
# Copy this file to .env and fill in your credentials

# AWS Bedrock Configuration (for AI analysis)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# AIS Data Provider Configuration
# Provider options: aisstream (free), aishub, marinetraffic
AIS_PROVIDER=aisstream

# Get your FREE API key at: https://aisstream.io (sign in with GitHub)
AIS_API_KEY=

# Note: If no AIS_API_KEY is provided, the application will run in demo mode
# with simulated vessel data for testing and development.
